# Copy to .env for local testing, or set these as Render environment
# variables in production. Nothing in this repo hardcodes real credentials.

SECRET_KEY=
# Use Supabase's POOLED connection string (Project Settings -> Database ->
# Connection pooling -> Transaction mode, port 6543), NOT the direct
# connection (port 5432) -- the direct host is IPv6-only in many Supabase
# regions and platforms like Render can't reach it, causing slow connection
# timeouts followed by a 500 with no row ever written. Pooled host/format
# differs from direct: postgres.<ref> as the username, a pooler.supabase.com
# host, port 6543.
DATABASE_URL=postgresql://postgres.tsxhuzsanoqahsrbumxz:PASSWORD@aws-0-<region>.pooler.supabase.com:6543/postgres

SUPABASE_URL=https://tsxhuzsanoqahsrbumxz.supabase.co
SUPABASE_SERVICE_KEY=
SUPABASE_PDF_BUCKET=lesson-pdfs
SIGNED_URL_TTL_SECONDS=3600

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

SENDGRID_API_KEY=
FROM_EMAIL=noreply@aimadesimple40.com
FROM_NAME=AI Made Simple 40+

PORTAL_BASE_URL=http://localhost:5000
